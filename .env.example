# ZiWei 环境配置模板
# 复制此文件为 .env 并填入真实的 API Key

# L0 - 决策脑 (Opus)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://cursor.scihub.edu.kg/api
L0_MODEL=claude-opus-4-6

# L1 - 执行管理层 (MiniMax M2.5)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
L1_MODEL=MiniMax-M2.5

# L2 - 执行层 (GLM 4.7)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-7

# 安全密钥
MANIFEST_SECRET=change-me-in-production-min-32-chars
ZIWEI_DB_PATH=.ziwei/ziwei.db
